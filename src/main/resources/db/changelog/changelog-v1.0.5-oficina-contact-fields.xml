<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
    http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="5" author="system">
        <comment>Adiciona campos email e telefone à tabela Oficina</comment>

        <addColumn tableName="oficina">
            <column name="email" type="varchar(255)">
                <constraints nullable="true"/>
            </column>
        </addColumn>

        <addColumn tableName="oficina">
            <column name="telefone" type="varchar(50)">
                <constraints nullable="true"/>
            </column>
        </addColumn>

        <createIndex indexName="idx_oficina_email" tableName="oficina">
            <column name="email"/>
        </createIndex>
    </changeSet>

</databaseChangeLog>

